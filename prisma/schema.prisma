generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Status {
  pending
  in_progress
  submitted
}

enum Priority {
  low
  medium
  high
}

model Course {
  id Int      @id @default(autoincrement())
  name        String
  createdAt    DateTime  @default(now())

  assignments Assignment[]
}

model Assignment {
  id       Int        @id @default(autoincrement())       
  title    String
  dueDate  DateTime
  status   Status
  description  String?
  priority    Priority  @default(medium)
  createdAt DateTime  @default(now())

  courseId    Int
  course     Course   @relation(fields:[courseId], references:[id])
}
